---
import BaseLayout from '../layouts/BaseLayout.astro'
import Badge from '../components/Badge.astro'
import Button from '../components/Button.astro'
import LedgerVisual from '../components/LedgerVisual.astro'
import Pillar from '../components/Pillar.astro'
import Callout from '../components/Callout.astro'
import Terminal from '../components/Terminal.astro'
import { base } from '../lib/path'
---
<BaseLayout title="attest: signed provenance for code changes">
<main id="main">

<section class="hero" aria-labelledby="hero-h">
  <div class="container">
    <div class="hero-grid">
      <div>
        <Badge dot>v0.1.0 · the trust layer for agent-written code</Badge>
        <h1 class="hero-h1" id="hero-h">Record <span class="seal">who vetted</span><br>this change, and prove it.</h1>
        <p class="hero-sub">A verifiable, policy-gated ledger of who reviewed what and at what confidence, keyed to commit SHAs and stored in git notes. Optionally Ed25519-signed. <strong>augur scores the risk; attest records the trust.</strong></p>
        <div class="hero-actions">
          <Button href={`${base}docs/quickstart`} variant="primary">Get started <span aria-hidden="true">→</span></Button>
          <Button href={`${base}docs/policy`} variant="secondary">Read the policy model</Button>
        </div>
        <p class="hero-fineprint">Zero setup: <code>attest sign --reviewer agent:claude --confidence 0.92</code></p>
      </div>
      <div>
        <LedgerVisual />
      </div>
    </div>
  </div>
</section>

<section class="stats" aria-label="Key numbers">
  <div class="container">
    <ul class="stats-grid">
      <li class="stat"><div class="num">11</div><div class="lbl">policy rules</div><div class="sub">all optional, permissive defaults</div></li>
      <li class="stat"><div class="num">0</div><div class="lbl">services</div><div class="sub">stored in git notes, no DB, no backend</div></li>
      <li class="stat"><div class="num">1</div><div class="lbl">key, optional</div><div class="sub">Ed25519, unsigned records still valid</div></li>
      <li class="stat"><div class="num">5</div><div class="lbl">subcommands</div><div class="sub">sign · verify · log · export · keygen</div></li>
    </ul>
  </div>
</section>

<section class="terminal-demo" aria-labelledby="demo-h">
  <div class="container">
    <header class="section-head">
      <p class="section-eyebrow">sign → verify</p>
      <h2 id="demo-h">Trust that <em>travels with the repo.</em></h2>
      <p>An agent records its verdict; a human signs off; a policy gates the merge. The record lives in <code>refs/notes/attest</code> and moves with every <code>git push</code>.</p>
    </header>
    <Terminal title="attest log then verify" ariaLabel="Showing the colored attestation ledger then verifying it against a policy">
      <div class="term-line"><span class="term-comment"># an agent scores the diff with augur and records it; a human files a signed sign-off</span></div>
      <div class="term-line"><span class="term-prompt">$</span> augur check --json | attest sign --commit HEAD --reviewer agent:claude --from-augur - --tests-passed</div>
      <div class="term-line"><span class="term-prompt">$</span> attest sign --commit HEAD --reviewer human:leif --confidence 0.72 --verdict review --human-approved --tests-passed --sign</div>
      <div class="term-line">&nbsp;</div>
      <div class="term-line"><span class="term-comment"># the ledger, in colour: green = proceed/verified, amber = review, cyan = reviewer, dim = unsigned</span></div>
      <div class="term-line"><span class="term-prompt">$</span> attest log --commit HEAD</div>
      <div class="term-line"><span class="term-bold">attest · ledger</span></div>
      <div class="term-line">&nbsp;</div>
      <div class="term-line"><span class="term-dim">&nbsp;&nbsp;commit abc1234567  (2 attestations)</span></div>
      <div class="term-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="term-good">[ok]</span> <span class="term-info">agent:claude</span>  <span class="term-good">verdict:proceed</span>  <span class="term-good">conf:95%</span>  <span class="term-good">tests:ok</span>  <span class="term-dim">human:-</span>  <span class="term-dim">unsigned</span></div>
      <div class="term-line">&nbsp;&nbsp;&nbsp;&nbsp;<span class="term-warn">[!]</span> <span class="term-info">human:leif</span>  <span class="term-warn">verdict:review</span>  <span class="term-warn">conf:72%</span>  <span class="term-good">tests:ok</span>  <span class="term-good">human:ok</span>  <span class="term-good">signed[ok]</span></div>
      <div class="term-line"><span class="term-dim">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;note: reviewed the migration by hand</span></div>
      <div class="term-line">&nbsp;</div>
      <div class="term-line"><span class="term-comment"># CI / the agent gates on the policy: exit code is the contract</span></div>
      <div class="term-line"><span class="term-prompt">$</span> attest verify --range origin/main..HEAD --policy .attest.json</div>
      <div class="term-line"><span class="term-bold">attest verify ·</span> <span class="term-good-bold">[ok] PASS</span> <span class="term-dim">(3 commits checked)</span></div>
      <div class="term-line"><span class="term-prompt">$</span> echo $?</div>
      <div class="term-line"><span class="term-out">0</span><span class="blink" aria-hidden="true"></span></div>
    </Terminal>
  </div>
</section>

<section class="pillars" aria-labelledby="pillars-h">
  <div class="container">
    <header class="section-head">
      <p class="section-eyebrow">The loop</p>
      <h2 id="pillars-h">Score, record, <em>gate.</em></h2>
      <p>Agents made code cheap; the scarce resource is now trust. attest is the missing primitive: a portable record an agent or a human can verify, and a policy CI can block on.</p>
    </header>

    <Callout type="tip">
      <p><strong>Why attest?</strong> When an agent lands a change, there is no native, portable record of which agent or human vetted it, and that context is lost the moment the PR merges. attest makes it durable: a signed artifact keyed to the commit SHA, stored in git notes, that travels with your repository across every git host.</p>
    </Callout>

    <ul class="pillars-grid">
      <Pillar
        step="Step 1"
        title="Record"
        command="$ attest sign --reviewer agent:claude --from-augur -"
        subItems={[
          { label: "augur pipe", description: "verdict + confidence auto-filled from augur's risk score" },
          { label: "git notes", description: "stored in refs/notes/attest, no service, no database" }
        ]}
      >
        Capture who or what reviewed a change, at what confidence, keyed to the commit SHA.
      </Pillar>

      <Pillar
        step="Step 2"
        title="Sign"
        command="$ attest keygen && attest sign … --sign"
        badge="Ed25519"
        subItems={[
          { label: "Optional", description: "unsigned records are still valid; signing is opt-in" },
          { label: "Pinned identity", description: "signerPinning binds human:leif to a key, stopping spoofs" }
        ]}
      >
        Attach a detached Ed25519 signature over a deterministic canonical form anyone can verify.
      </Pillar>

      <Pillar
        step="Step 3"
        title="Gate"
        command="$ attest verify --policy .attest.json"
        subItems={[
          { label: "Exit-code gate", description: "non-zero on any violation; CI and agent loops gate on it" },
          { label: "Audit export", description: "attest export: one stable JSON document for compliance" }
        ]}
      >
        Block a merge when a commit lacks the trust a policy demands, so an agent escalates instead of merging blind.
      </Pillar>
    </ul>
  </div>
</section>

<section class="trust-layer" aria-labelledby="tl-h">
  <div class="container">
    <header class="section-head">
      <p class="section-eyebrow">attest + augur</p>
      <h2 id="tl-h">augur scores the risk.<br><em>attest records the trust.</em></h2>
      <p><a href="https://github.com/CorvidLabs/augur">augur</a> answers <em>how risky is this diff, and should a human look?</em>, but that verdict is ephemeral. attest makes it durable: a portable, optionally-signed record of what vetted a change, and a policy CI and agents can gate on. They compose over a pipe; attest never links augur.</p>
    </header>
    <div class="tl-pipe">
      <span aria-hidden="true" style="color: var(--accent-bright);">$</span>
      <code>augur check --json | attest sign --from-augur -</code>
    </div>
    <p class="tl-note"><code>--from-augur</code> copies augur's <code>verdict</code> and maps its <code>riskScore</code> (0…100) to <code>confidence = 1 − riskScore/100</code>. A risk-45 <code>review</code> diff becomes a 0.55-confidence attestation.</p>
  </div>
</section>

<section class="cta-banner" aria-labelledby="cta-h">
  <div class="container">
    <h2 id="cta-h">Stop losing the <em>trust trail.</em><br>Make provenance portable.</h2>
    <p>Build attest, record your first attestation, and verify it against a policy in under a minute.</p>
    <div class="cta-install">
      <span aria-hidden="true" style="color: var(--accent-bright);">$</span>
      <code>swift build -c release &amp;&amp; install .build/release/attest /usr/local/bin</code>
    </div>
    <div class="cta-actions">
      <Button href={`${base}docs`} variant="primary">Read the docs</Button>
      <Button href={`${base}docs/signing`} variant="secondary">Signing &amp; identity</Button>
    </div>
  </div>
</section>

</main>
</BaseLayout>

<style>
  main { background-image: radial-gradient(ellipse 1200px 600px at 50% -200px, rgba(225,29,72,0.12), transparent 70%); }
  .hero { padding: 80px 0 60px; }
  .hero-grid { display: grid; grid-template-columns: 1fr 1.15fr; gap: 56px; align-items: center; }
  .hero-h1 { font-size: clamp(2.4rem, 5vw, 3.6rem); line-height: 1.05; letter-spacing: -0.025em; margin: 22px 0; }
  .hero-h1 .seal { background: linear-gradient(120deg, var(--accent-bright) 0%, var(--accent) 60%, var(--accent-deep) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    font-style: italic; font-family: var(--serif); font-weight: 500; }
  .hero-sub { color: var(--text-muted); font-size: 1.125rem; max-width: 500px; margin-bottom: 28px; line-height: 1.6; }
  .hero-sub strong { color: var(--accent-bright); font-weight: 600; }
  .hero-actions { display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap; }
  .hero-fineprint { color: var(--text-muted); font-size: 0.9375rem; }
  .hero-fineprint code { background: var(--bg-raised); padding: 4px 8px; border-radius: 4px;
    border: 1px solid var(--border); color: var(--accent-bright);
    font-family: var(--mono); font-size: 0.8125rem; }
  .stats { padding: 60px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin-top: 40px; background: linear-gradient(180deg, transparent, rgba(225,29,72,0.025), transparent); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .stat .num { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.02em;
    color: var(--accent-bright); font-family: var(--serif); line-height: 1; }
  .stat .lbl { color: var(--text); font-size: 1rem; margin-top: 8px; font-weight: 500; }
  .stat .sub { color: var(--text-muted); font-size: 0.875rem; margin-top: 4px; }
  .terminal-demo { padding: 90px 0 30px; }
  .section-head { margin-bottom: 32px; }
  .section-eyebrow { color: var(--accent-bright); font-size: 0.875rem; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 14px; }
  .section-head h2 { font-size: clamp(1.85rem, 3.5vw, 2.6rem); letter-spacing: -0.02em;
    max-width: 620px; line-height: 1.15; margin-bottom: 14px; }
  .section-head h2 em { font-style: italic; font-family: var(--serif);
    color: var(--accent-bright); font-weight: 400; }
  .section-head p { color: var(--text-muted); font-size: 1.0625rem; max-width: 620px; }
  .section-head p code { font-family: var(--mono); font-size: 0.875em; color: var(--accent-bright);
    background: var(--bg-raised); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }
  .section-head p a { color: var(--accent-bright); text-decoration: underline; text-underline-offset: 3px; }
  .pillars { padding: 90px 0 60px; }
  .pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 28px; }
  .trust-layer { padding: 80px 0; background: linear-gradient(180deg, transparent, rgba(225,29,72,0.03)); }
  .tl-pipe { display: inline-flex; align-items: center; gap: 14px; padding: 16px 22px;
    background: var(--bg-raised); border: 1px solid var(--border-strong); border-radius: 10px;
    font-family: var(--mono); font-size: 0.9375rem; margin-bottom: 18px; overflow-x: auto; max-width: 100%; }
  .tl-pipe code { font-family: var(--mono); white-space: pre; }
  .tl-note { color: var(--text-muted); font-size: 0.9375rem; max-width: 640px; line-height: 1.6; }
  .tl-note code { font-family: var(--mono); font-size: 0.875em; color: var(--accent-bright);
    background: var(--bg-raised); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--border); }
  .cta-banner { padding: 120px 0 100px; text-align: center; position: relative; overflow: hidden; }
  .cta-banner::before { content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 800px 400px at center, var(--accent-glow), transparent 70%);
    pointer-events: none; }
  .cta-banner > * { position: relative; }
  .cta-banner h2 { font-size: clamp(2rem, 4vw, 2.8rem); max-width: 680px;
    margin: 0 auto 16px; letter-spacing: -0.02em; line-height: 1.15; }
  .cta-banner h2 em { font-family: var(--serif); font-style: italic; color: var(--accent-bright); font-weight: 400; }
  .cta-banner p { color: var(--text-muted); margin: 0 auto 28px; max-width: 480px; font-size: 1.0625rem; }
  .cta-install { display: inline-flex; align-items: center; gap: 14px; padding: 16px 22px;
    background: var(--bg-raised); border: 1px solid var(--border-strong); border-radius: 10px;
    font-family: var(--mono); font-size: 0.875rem; overflow-x: auto; max-width: 100%; }
  .cta-install code { white-space: pre; }
  .cta-actions { display: flex; gap: 12px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
  @media (max-width: 900px) { .hero-grid, .stats-grid { grid-template-columns: 1fr; } }
  @media (max-width: 768px) { .pillars-grid { grid-template-columns: 1fr; } }
</style>
