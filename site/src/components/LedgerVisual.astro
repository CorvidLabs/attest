---
interface Props {
  ariaLabel?: string
}
const { ariaLabel = 'attest ledger showing a signed verified attestation and a flagged unsigned spoof' } = Astro.props
---
<figure class="ledger-visual" aria-label={ariaLabel}>
  <div class="ledger-panel">
    <div class="ledger-header">
      <span class="ledger-icon" aria-hidden="true">🔏</span>
      <span class="ledger-filename">attest log · commit 9f2c1a7b04</span>
    </div>
    <div class="ledger-body">
      <!-- A trusted, signed, verified record -->
      <div class="rec rec-ok">
        <div class="rec-row">
          <span class="rec-badge rec-badge-ok" aria-label="passes policy">ok</span>
          <span class="rec-who">agent:claude</span>
          <span class="rec-verdict">verdict:proceed</span>
          <span class="rec-conf">conf:92%</span>
        </div>
        <div class="rec-meta">tests:ok · human:— · <span class="rec-signed">signed[ok]</span></div>
      </div>

      <!-- A separate human sign-off -->
      <div class="rec rec-ok">
        <div class="rec-row">
          <span class="rec-badge rec-badge-ok" aria-label="passes policy">ok</span>
          <span class="rec-who">human:leif</span>
          <span class="rec-verdict">verdict:review</span>
          <span class="rec-conf">conf:95%</span>
        </div>
        <div class="rec-meta">tests:ok · human:ok · <span class="rec-signed">signed[ok]</span></div>
      </div>

      <!-- A spoof attempt: claims human:leif but unsigned -->
      <div class="rec rec-spoof">
        <div class="rec-row">
          <span class="rec-badge rec-badge-spoof" aria-label="policy violation">!</span>
          <span class="rec-who">human:leif</span>
          <span class="rec-verdict">verdict:proceed</span>
          <span class="rec-conf">conf:99%</span>
        </div>
        <div class="rec-spoof-marker">
          <span class="spoof-icon" aria-label="spoof warning">⚠</span>
          <span class="spoof-label">pinned reviewer — unsigned · rejected by signerPinning</span>
        </div>
      </div>
    </div>
  </div>

  <div class="ledger-footer" aria-live="polite">
    <span class="verify-fail">attest verify · [x] FAIL — exit 1</span>
    <span class="verify-hint"> — <code>human:leif</code> is pinned but this record is unsigned</span>
  </div>
</figure>

<style>
  .ledger-visual {
    display: flex;
    flex-direction: column;
    gap: 0;
    font-family: var(--mono);
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .ledger-panel {
    background: var(--bg-raised);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45), 0 0 60px var(--accent-glow);
  }

  .ledger-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid var(--border);
  }

  .ledger-icon { font-size: 0.9375rem; line-height: 1; }
  .ledger-filename { color: var(--text-muted); font-size: 0.8125rem; letter-spacing: 0.01em; }

  .ledger-body { padding: 14px 16px; display: flex; flex-direction: column; gap: 12px; }

  .rec { border-left: 2px solid var(--border-strong); padding-left: 12px; }
  /* The verified record keeps SEMANTIC green cues even on the red-branded site —
     green = "verified", mirroring the CLI's terminal colours. Brand went red; the
     trust/success signal deliberately did not. */
  .rec-ok { border-left-color: var(--ok); }
  .rec-spoof { border-left-color: var(--warn); background: var(--warn-muted);
    margin-left: -4px; padding: 4px 0 4px 14px; border-radius: 0 6px 6px 0; }

  .rec-row { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .rec-badge { display: inline-grid; place-items: center; width: 22px; height: 22px;
    border-radius: 5px; font-weight: 700; font-size: 0.75rem; flex-shrink: 0; }
  .rec-badge-ok { background: var(--ok-muted); color: var(--ok-bright); border: 1px solid rgba(52,211,153,0.3); }
  .rec-badge-spoof { background: var(--warn-muted); color: var(--warn); border: 1px solid rgba(251,191,36,0.35); }
  /* reviewer identities are cyan, mirroring the CLI's terminal colour */
  .rec-who { color: var(--info); font-weight: 600; }
  .rec-verdict { color: var(--text-muted); }
  .rec-conf { color: var(--ok-bright); }
  .rec-meta { color: var(--text-dim); font-size: 0.8125rem; margin-top: 4px; padding-left: 32px; }
  .rec-signed { color: var(--ok-bright); }

  .rec-spoof-marker { display: flex; align-items: center; gap: 6px; margin-top: 4px;
    padding-left: 32px; color: var(--warn); font-size: 0.8125rem; }
  .spoof-icon { font-size: 0.875rem; line-height: 1; }
  .spoof-label { font-style: italic; letter-spacing: 0.01em; opacity: 0.95; }

  .ledger-footer { margin-top: 14px; text-align: center; font-size: 0.875rem; color: var(--text-dim); }
  .verify-fail { color: var(--block); font-weight: 600; }
  .verify-hint { color: var(--text-dim); }
  .verify-hint code { color: var(--text-muted); font-family: var(--mono); font-size: inherit;
    background: none; border: none; padding: 0; }
</style>
